# Copy this file to .env before running the self-host Compose path.
# Replace every local example secret before a household relies on it.

# Public origins. The default same-machine hostname works for browsers and
# containers on one host. For LAN or reverse-proxy use, replace every
# stuffstash.localhost value with the same reachable host or DNS name.
STUFF_STASH_SELFHOST_HOSTNAME=stuffstash.localhost
STUFF_STASH_WEB_ORIGIN=https://stuffstash.localhost:8081
STUFF_STASH_API_ORIGIN=https://stuffstash.localhost:8080
STUFF_STASH_WEB_PORT=8081
STUFF_STASH_HTTP_PORT=8080

# Dex OIDC. The bundled Dex service is the default self-host identity provider.
# The API accepts ID tokens whose audience is in STUFF_STASH_OIDC_CLIENT_IDS.
# The web app uses the public web client ID and redirect URI.
STUFF_STASH_AUTH_MODE=oidc
STUFF_STASH_OIDC_ISSUER=https://stuffstash.localhost:5556/dex
STUFF_STASH_OIDC_CLIENT_ID=stuff-stash-local
STUFF_STASH_WEB_OIDC_CLIENT_ID=stuff-stash-web-local
STUFF_STASH_WEB_OIDC_REDIRECT_URI=https://stuffstash.localhost:8081/callback
STUFF_STASH_OIDC_CLIENT_IDS=stuff-stash-local,stuff-stash-web-local,stuff-stash-mobile-local
STUFF_STASH_OIDC_MOBILE_CLIENT_ID=stuff-stash-mobile-local
STUFF_STASH_OIDC_MOBILE_REDIRECT_URI=stuffstash://auth/callback
STUFF_STASH_OIDC_MOBILE_SCOPES=openid,email,profile,offline_access
DEX_HTTP_PORT=5556
DEX_CONFIG_PATH=./deploy/selfhost/dex/config.yaml

# API adapters.
STUFF_STASH_AUTHZ_MODE=spicedb
STUFF_STASH_REPOSITORY_MODE=postgres
STUFF_STASH_BLOB_STORAGE_MODE=s3
STUFF_STASH_CORS_ALLOWED_ORIGINS=https://stuffstash.localhost:8081

# Published Stuff Stash images. Release automation updates these immutable
# digest references when it publishes new API and web images.
STUFF_STASH_API_IMAGE=ghcr.io/elsell/stuffstash@sha256:bb98b8fd9bfa723d760431fccc99edd27dcf671a691868b7bbcec1ec8aee5f24
STUFF_STASH_WEB_IMAGE=ghcr.io/elsell/stuffstash-web@sha256:ea2fb6970d62577669acda13f4cd77e38bc6ac52147e4d17ddd862645ba961a7

# API limits and workers.
STUFF_STASH_HTTP_RATE_LIMIT_ENABLED=true
STUFF_STASH_HTTP_RATE_LIMIT_REQUESTS=1200
STUFF_STASH_HTTP_RATE_LIMIT_WINDOW=1m
STUFF_STASH_HTTP_RATE_LIMIT_BURST=600
STUFF_STASH_AUTHORIZATION_OUTBOX_DRAIN_LIMIT=25
STUFF_STASH_AUTHORIZATION_OUTBOX_DRAIN_INTERVAL=10s
STUFF_STASH_AUTHORIZATION_OUTBOX_CLAIM_LEASE=30s
STUFF_STASH_BLOB_DELETION_OUTBOX_DRAIN_LIMIT=25
STUFF_STASH_BLOB_DELETION_OUTBOX_DRAIN_INTERVAL=10s
STUFF_STASH_BLOB_DELETION_OUTBOX_CLAIM_LEASE=30s
STUFF_STASH_BLOB_DELETION_OUTBOX_MAX_ATTEMPTS=5
STUFF_STASH_IMPORT_JOB_TIMEOUT_SECONDS=900
STUFF_STASH_IMPORT_CREDENTIAL_VACUUM_INTERVAL_SECONDS=60
STUFF_STASH_DEFAULT_PAGE_LIMIT=50
STUFF_STASH_MAX_PAGE_LIMIT=100

# Provider credential sealing. Generate the key with: openssl rand -base64 32
STUFF_STASH_PROVIDER_CREDENTIAL_KEY_ID=selfhost-key-1
STUFF_STASH_PROVIDER_CREDENTIAL_KEY=AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=

# Postgres for Stuff Stash metadata.
POSTGRES_IMAGE=postgres:18.1-alpine@sha256:aa6eb304ddb6dd26df23d05db4e5cb05af8951cda3e0dc57731b771e0ef4ab29
POSTGRES_DB=stuffstash
POSTGRES_USER=stuffstash
POSTGRES_PASSWORD=change-me-postgres

# SpiceDB with durable Postgres datastore.
SPICEDB_IMAGE=authzed/spicedb:v1.47.1@sha256:25c5499a43fdb206b7b1b72da4ba7ca911d92fd80d4d08ce2e95bf7ea0709788
STUFF_STASH_SPICEDB_PRESHARED_KEY=change-me-spicedb-preshared-key
STUFF_STASH_SPICEDB_TLS_ENABLED=false
STUFF_STASH_SPICEDB_BOOTSTRAP_SCHEMA=true
STUFF_STASH_SPICEDB_SCHEMA_PATH=/deploy/spicedb/schema.zed
SPICEDB_POSTGRES_DB=spicedb
SPICEDB_POSTGRES_USER=spicedb
SPICEDB_POSTGRES_PASSWORD=change-me-spicedb-postgres

# Garage/S3-compatible media storage. STUFF_STASH_S3_PUBLIC_ENDPOINT is the
# browser-reachable host and port without a scheme.
GARAGE_IMAGE=dxflrs/garage:v2.3.0@sha256:866bd13ed2038ba7e7190e840482bc27234c4afaf77be8cfa439ae088c1e4690
GARAGE_S3_PORT=3900
STUFF_STASH_S3_ENDPOINT=stuffstash.localhost:3900
STUFF_STASH_S3_PUBLIC_ENDPOINT=stuffstash.localhost:3900
STUFF_STASH_S3_ACCESS_KEY=change-me-garage-access-key
STUFF_STASH_S3_SECRET_KEY=change-me-garage-secret-key-change-me-garage-secret-key
STUFF_STASH_S3_BUCKET=stuffstash
STUFF_STASH_S3_REGION=garage
STUFF_STASH_S3_SECURE=true
STUFF_STASH_MAX_ATTACHMENT_BYTES=5242880

# Voice providers are disabled by default in self-host Compose.
STUFF_STASH_VOICE_DEV_FAKE_ENABLED=false
STUFF_STASH_VOICE_GOOGLE_ENABLED=false
STUFF_STASH_GOOGLE_CLOUD_PROJECT=
STUFF_STASH_GOOGLE_CLOUD_LOCATION=us-central1
STUFF_STASH_GOOGLE_GEMINI_MODEL=gemini-2.5-flash-lite
STUFF_STASH_GOOGLE_TTS_LANGUAGE_CODE=en-US
STUFF_STASH_GOOGLE_TTS_VOICE_NAME=en-US-Standard-C
STUFF_STASH_GOOGLE_CREDENTIAL_MODE=adc
STUFF_STASH_GOOGLE_ACCESS_TOKEN=

# Build/runtime images. Keep these digest-pinned.
GO_BUILDER_IMAGE=registry.access.redhat.com/hi/go:1.25.10-builder-1780418048@sha256:1a99d42f555db97455998945faf3c797c1f65ce1b92e4d9952a589446d114d6c
RUNTIME_IMAGE=registry.access.redhat.com/hi/core-runtime:2.42-1781714135@sha256:82ab1238082f405e19e1cc6e4950549371b6742ba6b649ca356c058249162540
NODE_BUILDER_IMAGE=registry.access.redhat.com/ubi9/nodejs-24@sha256:27dbb10d06365cc4627e4abb589780b3603feaac2577a231f95c193abfa0c04b
WEB_RUNTIME_IMAGE=registry.access.redhat.com/ubi9/nginx-124@sha256:da5615d3613867c87aefc2cfdfcc8bb5e3c5e1f778d91e26ef72ae5a7824e386
DEX_IMAGE=dexidp/dex:v2.44.0@sha256:5d0656fce7d453c0e3b2706abf40c0d0ce5b371fb0b73b3cf714d05f35fa5f86
CADDY_IMAGE=caddy:2.10.2@sha256:c3d7ee5d2b11f9dc54f947f68a734c84e9c9666c92c88a7f30b9cba5da182adb
PNPM_VERSION=11.0.7
